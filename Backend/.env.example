# ─────────────────────────────────────────────
# LeadPilot AI — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# SMTP Email (e.g. Gmail, SendGrid, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@yourcompany.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM_NAME=LeadPilot AI
EMAIL_FROM_ADDRESS=you@yourcompany.com

# Google Calendar
# Base URL for the scheduling link shown to leads
# Replace with your real Calendly / Cal.com / Google Calendar link for demo
CALENDAR_BASE_URL=https://calendar.google.com/calendar/appointments/schedules/YOUR_SCHEDULE_ID

# App
APP_ENV=development
APP_TITLE=LeadPilot AI
APP_VERSION=1.0.0
